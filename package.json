{
  "name": "@cesarechazu/directus-extension-generate-pdf",
  "description": "Directus Flow operation to generate generic PDFs from JSON using pdfme",
  "icon": "picture_as_pdf",
  "version": "1.0.2",
  "author": "Cesar Echazu",
  "license": "GPL-3.0-or-later",
  "keywords": [
    "directus",
    "directus-extension",
    "directus-operation",
    "pdf",
    "pdfme",
    "flows"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cesarechazu/directus-extension-generate-pdf.git"
  },
  "homepage": "https://github.com/cesarechazu/directus-extension-generate-pdf#readme",
  "bugs": {
    "url": "https://github.com/cesarechazu/directus-extension-generate-pdf/issues"
  },
  "type": "module",
  "scripts": {
    "build": "mkdir -p dist/fonts && cp src/app.js dist/app.js && cp src/api.js dist/api.js && cp fonts/Roboto-Bold.ttf dist/fonts/Roboto-Bold.ttf",
    "prepack": "npm run build",
    "test": "node --test"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "dependencies": {
    "@pdfme/common": "5.5.8",
    "@pdfme/generator": "5.5.8",
    "@pdfme/schemas": "5.5.8"
  },
  "directus:extension": {
    "type": "operation",
    "host": "^11.0.0",
    "path": {
      "app": "dist/app.js",
      "api": "dist/api.js"
    },
    "source": {
      "app": "src/app.js",
      "api": "src/api.js"
    }
  }
}
